{
  "name": "sf-express-tracker",
  "version": "1.0.0",
  "description": "顺丰快递批量查询前端应用",
  "private": true,
  "dependencies": {
    "axios": "^1.11.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-scripts": "5.0.1"
  },
  "scripts": {
    "start": "react-scripts start",
    "build": "react-scripts build",
    "test": "react-scripts test",
    "eject": "react-scripts eject",
    "setup": "chmod +x scripts/setup.sh && scripts/setup.sh",
    "setup:win": "scripts\\setup.bat",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx",
    "preview": "npm run build && npx serve -s build"
  },
  "eslintConfig": {
    "extends": [
      "react-app",
      "react-app/jest"
    ]
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "devDependencies": {
    "@types/node": "^16.18.0",
    "@types/react": "^18.2.0",
    "@types/react-dom": "^18.2.0"
  }
}
